# Server & App Configuration
APP_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:3001"
CORS_ORIGINS="http://localhost:3001,http://localhost:3000,https://your-production-domain.com"

# Database Configuration
DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>?schema=public"

# JWT Authentication
JWT_SECRET="your_strong_random_secret_here"
LOGIN_URL="http://localhost:3000/auth/login"

# Supabase S3 Storage Configuration
B2_ENDPOINT="https://<your_project_ref>.supabase.co/storage/v1/s3"
B2_ACCESS_KEY_ID="your_supabase_access_key"
B2_SECRET_ACCESS_KEY="your_supabase_secret_key"
B2_BUCKET_NAME="your_bucket_name"
B2_REGION="your_supabase_region"

# Email Configuration (SMTP / Gmail)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER="your_email@gmail.com" 
SMTP_PASSWORD="your_16_letter_app_password" 
SMTP_FROM="Eduhub <noreply@yourdomain.com>"

# Email Configuration (Resend - Alternative)
RESEND_API_KEY="your_resend_api_key_here"
RESEND_FROM_EMAIL="Eduhub <onboarding@resend.dev>"