generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------------
// MULTI-TENANCY CORE
// ------------------------------------------------------
model Institution {
  id          String   @id @default(uuid())
  name        String   // e.g., "Engineering College A"
  branch      String?
  joinCode    String   @unique // For students to type in when registering
  createdAt   DateTime @default(now())
  
  // Relations: Everything belongs to an institution
  users       User[]
  invitations Invitation[]
  notices     Notice[]
  subjects    Subject[]
}

model User {
  id        String            @id @default(uuid())
  email     String            @unique
  password  String
  firstName String
  lastName  String
  role      Role              @default(STUDENT)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  // Student-Specific Field
  registrationNumber String?  
  
  // The Multi-Tenant Link
  institutionId      String
  institution        Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  notices   Notice[]
  resources LibraryResource[]
  comments  Comment[]
  upvotes   Upvote[]
  createdAssignments Assignment[] @relation("CreatedAssignments")
  submissions        Submission[] @relation("UserSubmissions")
  passwordHistory    PasswordHistory[]
  createdSubjects    Subject[]

  requiresPasswordReset Boolean? @default(false)

  // Ensure an email is only unique WITHIN a specific college
  @@unique([email, institutionId])
}

// ------------------------------------------------------
// PASSWORD HISTORY
// ------------------------------------------------------
model PasswordHistory {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash String
  createdAt DateTime @default(now())
}

// ------------------------------------------------------
// INVITATION SYSTEM
// ------------------------------------------------------
model Invitation {
  id            String   @id @default(uuid())
  email         String   @unique
  token         String   @unique
  role          Role     @default(TEACHER)
  isUsed        Boolean  @default(false)
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  // The Multi-Tenant Link (Crucial so the teacher joins the right college)
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  // A teacher can only have one active invite per college
  @@unique([email, institutionId])
}

model Notice {
  id        String    @id @default(uuid())
  title     String
  content   String
  authorId  String
  createdAt DateTime  @default(now())
  subject   String    @default("General")
  expiresAt DateTime?
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  author    User      @relation(fields: [authorId], references: [id])

  // Multi-Tenant Link
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
}

model Subject {
  id        String            @id @default(uuid())
  name      String            
  category  SubjectCategory // this determines if it's a teacher or student resource
  resources LibraryResource[]
  assignments Assignment[]
  createdAt DateTime          @default(now())

  // Track who created this subject
  createdBy String
  creator   User              @relation(fields: [createdBy], references: [id])

  // Multi-Tenant Link
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  // Ensure a name is unique per category (so you can have "Math" in both)
  @@unique([name, category, institutionId])
}

model LibraryResource {
  id          String   @id @default(uuid())
  title       String
  description String?
  fileUrl     String
  fileType    String
  fileSize    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  uploaderId  String
  uploader    User     @relation(fields: [uploaderId], references: [id])
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  comments    Comment[]
  upvotes     Upvote[]        // Only used/displayed for STUDENT_RESOURCE in frontend
}

model Comment {
  id         String          @id @default(uuid())
  content    String
  
  // Relations
  resourceId String
  resource   LibraryResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  
  authorId   String
  author     User            @relation(fields: [authorId], references: [id])

  // --- Threaded Replies Logic ---
  //parentId   String?         // If null, it's a top-level comment
  //parent     Comment?        @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  //replies    Comment[]       @relation("CommentReplies")
  // ------------------------------

  createdAt  DateTime        @default(now())
}

model Upvote {
  id         String          @id @default(uuid())
  
  // Relations
  userId     String
  user       User            @relation(fields: [userId], references: [id])
  
  resourceId String
  resource   LibraryResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  // Ensure a user can only upvote a specific resource ONCE
  @@unique([userId, resourceId]) 
}

model Assignment {
  id           String       @id @default(uuid())
  title        String
  description  String?
  fileUrl      String?      // The question paper/instructions
  dueDate      DateTime
  isLateAllowed Boolean
  
  // Link to Subject (Connecting to the official Teacher subjects)
  subjectId    String
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  
  // The User who created this (Teacher)
  creatorId    String
  creator      User         @relation("CreatedAssignments", fields: [creatorId], references: [id])
  
  submissions  Submission[]

  createdAt    DateTime     @default(now())
}

model Submission {
  id             String           @id @default(uuid())
  fileUrl        String           // The student's answer file
  submittedAt    DateTime         @default(now())
  submissionStatus SubmissionStatus @default(SUBMITTED)
  reviewStatus   ReviewStatus     @default(PENDING_REVIEW)
  isLate         Boolean          @default(false)
  grade          String?
  feedback       String?
  
  // Relations
  assignmentId   String
  assignment     Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  
  // The User who submitted this (Student)
  submitterId    String
  submitter      User             @relation("UserSubmissions", fields: [submitterId], references: [id])

  @@unique([submitterId, assignmentId]) // One submission per student per assignment
}

enum Role {
  STUDENT
  TEACHER
  COLLEGE_ADMIN // Added this so colleges can manage their own invites
  SUPER_ADMIN   // Added this for you (the platform owner)
}

enum SubjectCategory {
  TEACHER_RESOURCE // For Library
  STUDENT_RESOURCE // For Library
  ASSIGNMENT       // For the Assignments Module
}

enum SubmissionStatus {
  SUBMITTED
  PENDING_SUBMISSION
}

enum ReviewStatus {
  PENDING_REVIEW
  GRADED
}
